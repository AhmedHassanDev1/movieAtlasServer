<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify Your Email</title>
</head>
<body style="margin:0;padding:0;background:#121212;font-family:Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding:40px 20px;">
        <table
          width="600"
          cellpadding="0"
          cellspacing="0"
          style="background:#1c1c1c;border-radius:12px;overflow:hidden;"
        >
          <tr>
            <td
              align="center"
              style="background:#FF0000;padding:24px;color:#000;font-size:28px;font-weight:bold;"
            >
             Movie Atlas
            </td>
          </tr>

          <tr>
            <td style="padding:40px;color:#ffffff;">
              <h2 style="margin-top:0;">
                Verify Your Email Address
              </h2>

              <p style="color:#cccccc;font-size:16px;line-height:1.6;">
                Welcome to MovieHub. Use the verification code below to
                complete your account registration.
              </p>

              <div
                style="
                  text-align:center;
                  margin:32px 0;
                "
              >
                <span
                  style="
                    display:inline-block;
                    background:#FF0000;
                    color:#000;
                    padding:16px 32px;
                    font-size:32px;
                    font-weight:bold;
                    letter-spacing:8px;
                    border-radius:8px;
                  "
                >
                  {{CODE}}
                </span>
              </div>

              <p style="color:#cccccc;font-size:14px;">
                This code will expire in 10 minutes.
              </p>

              <p style="color:#cccccc;font-size:14px;">
                If you didn't create an account, you can safely ignore this
                email.
              </p>
            </td>
          </tr>

          <tr>
            <td
              align="center"
              style="
                padding:20px;
                background:#181818;
                color:#888888;
                font-size:12px;
              "
            >
              © 2026 MovieHub. All rights reserved.
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>